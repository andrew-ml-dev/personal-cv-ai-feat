# Copy to `.env` and adjust. Only `VITE_*` keys are exposed to browser code.
# Consumed from `src/config/env.js`, `profile.js`, `contact.js`, `nav.js`, etc.

# ——— API ————————————————————————————————————————————————————————————————
# Base for `fetch()`: `/api` with Vite dev proxy, or e.g. `http://127.0.0.1:8000/api`
VITE_BACKEND_URL=/api
VITE_CHAT_PATH=chat
VITE_API_STATS_PATH=/api/chat/stats
VITE_STATS_POLL_INTERVAL_MS=500

# Vite dev only: port and proxy target when VITE_BACKEND_URL is not http(s).
VITE_DEV_SERVER_PORT=5173
VITE_DEV_PROXY_TARGET=http://localhost:8000

# ——— index.html (vite.config transformIndexHtml) ———————————————————————————
VITE_HTML_TITLE=Andrzej Ludkiewicz — AI Engineer
VITE_GOOGLE_FONTS_CSS=https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap

# ——— Profile / sidebar ————————————————————————————————————————————————————
VITE_FIRST_NAME=Andrzej
VITE_LAST_NAME=Ludkiewicz
VITE_INITIALS=AL
VITE_JOB_TITLE=AI Engineer
VITE_AVATAR_IMAGE_URL=https://media.licdn.com/dms/image/v2/C4D03AQFPh5lTJrlp1Q/profile-displayphoto-shrink_400_400/profile-displayphoto-shrink_400_400/0/1608738255554?e=1775692800&v=beta&t=t6bzlJV5fmmaSPsivqjk_AqdW-L5fbvM9CFrtx3aFZk
VITE_AVAILABILITY_SHOW=true
VITE_AVAILABILITY_LABEL=Open to work
VITE_STAT_LABEL_YOE=YOE
VITE_STAT_VALUE_YOE=7+
VITE_STAT_LABEL_FPS=FPS
VITE_STAT_VALUE_FPS=83
VITE_STAT_LABEL_MAP=mAP
VITE_STAT_VALUE_MAP=94%
VITE_LOCATION=Kraków, PL
VITE_GITHUB_USERNAME=andrew-ml-dev
VITE_FOOTER_TAGLINE=Powered by FastAPI · Edge AI
VITE_TOPBAR_LIVE_LABEL=Live on Raspberry Pi 5 Edge
