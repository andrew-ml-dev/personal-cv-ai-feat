LLAMA_HOST=localhost
LLAMA_PORT=8090
CORS_ALLOW_ORIGINS='["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]'
LLAMA_API_PATH=/v1/chat/completions
TEMPERATURE=0.2
RESPONSE_DELAY_SECONDS=0.03
RESUME_MARKDOWN_URL=https://raw.githubusercontent.com/your-user/your-repo/main/resume.md
RESUME_MARKDOWN_TTL_SECONDS=600
CHROMA_PATH=/chroma_data
CHROMA_COLLECTION=cv_chunks
QDRANT_TOP_K=4
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
USE_VECTOR_SEARCH=true
INDEX_API_KEY=change-me-or-leave-empty-to-disable-auth